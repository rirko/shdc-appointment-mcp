{
  "name": "shdc-appointment-mcp",
  "version": "0.1.0",
  "description": "MCP stdio server for Shanghai SHDC appointment workflow.",
  "type": "module",
  "bin": {
    "shdc-appointment-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.13.2",
    "sm-crypto": "^0.3.13",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=20"
  }
}
